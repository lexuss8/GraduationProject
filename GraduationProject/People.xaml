<Window x:Class="GraduationProject.People"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject"
        mc:Ignorable="d" Icon="/Images/Logo.png"
        Title="ГИБДД: База данных людей" Height="1000" Width="1900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Background.jpg"/>
        </Grid.Background>
        <TextBox Name="tb_search" HorizontalAlignment="Center" Margin="0,29,0,0" TextWrapping="Wrap" FontSize="17" VerticalContentAlignment="Center"
         Text="🔍 Поиск" TextChanged="tb_search_text_changed" HorizontalContentAlignment="Center" Width="552" Height="33" VerticalAlignment="Top"
         GotFocus="tb_search_got_focus" LostFocus="tb_search_lost_focus" Foreground="Gray"/>
        <DataGrid Name="data_grid_people" ItemsSource="{Binding}" AutoGenerateColumns="False" FontSize="15" CanUserAddRows="False"
         IsReadOnly="True" Margin="89,89,89,130">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Фамилия}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding Имя}" />
                <DataGridTextColumn Header="Отчество" Binding="{Binding Отчество}" />
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding Дата_рождения}" />
                <DataGridTemplateColumn Header="Фото" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Фото}" MouseLeftButtonUp="Image_click"
                                Width="100" Height="60" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="ИНН" Binding="{Binding ИНН}" />
                <DataGridTextColumn Header="Паспорт" Binding="{Binding Паспорт}" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" />
                <DataGridTextColumn Header="Прописка" Binding="{Binding Прописка}" />
            </DataGrid.Columns>
        </DataGrid>
        <Image x:Name="image_big" Visibility="Hidden"
       Stretch="Uniform" Margin="205,144,205,184" MouseLeftButtonUp="Big_image_click"/>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
    </Grid>
</Window>
