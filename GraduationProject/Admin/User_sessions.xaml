<Window x:Class="GraduationProject.Admin.User_sessions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject.Admin"
        mc:Ignorable="d"
        Title="ГИБДД: Управление сессиями" Height="1000" Width="1900"
        Icon="/Images/Logo.png"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Background.jpg"/>
        </Grid.Background>
        <DataGrid FontSize="16" Name="data_grid_table_sessions" BeginningEdit="data_grid_table_sessions_beginning_edit"
        SelectionChanged="data_grid_table_sessions_SelectionChanged"     
        CanUserAddRows="False" AutoGenerateColumns="True" HeadersVisibility="Column" RowHeaderWidth="0" Margin="189,87,189,218">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFB8D8FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
        <Button Content="Отменить"
        Name="Button_cancel"
        Click="Button_Click_cancel"
        Visibility="Collapsed"
        FontSize="24"
        HorizontalAlignment="Right"
        Margin="0,0,857,31"
        VerticalAlignment="Bottom"
        Height="66"
        Width="172"/>
        <Button Content="Завершить сессию"
        Name="Button_end_session"
        Click="Button_Click_end_session"
        IsEnabled="False"
        FontSize="24"
        HorizontalAlignment="Right"
        Margin="0,0,857,31"
        VerticalAlignment="Bottom"
        Height="66"
        Width="220"/>
        <ComboBox Name="ComboBox_export"
          SelectionChanged="ComboBox_export_SelectionChanged"
          FontSize="22"
          HorizontalAlignment="Right"
          Margin="0,0,1142,31"
          VerticalAlignment="Bottom"
          Height="66"
          Width="220"
          SelectedIndex="0"
          VerticalContentAlignment="Center"
          HorizontalContentAlignment="Center">
            <ComboBoxItem Content="Выберите экспорт" IsEnabled="False"/>
            <ComboBoxItem Content="Экспорт в PDF"/>
            <ComboBoxItem Content="Экспорт в Excel"/>
        </ComboBox>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Добавить" Click="Button_Click_add" FontSize="24" HorizontalAlignment="Right" Margin="0,0,160,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Сохранить" Name="Button_save" Click="Button_Click_save" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,389,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
        <Button Content="Редактировать" Name="Button_edit" Click="Button_Click_edit" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,623,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
    </Grid>
</Window>
