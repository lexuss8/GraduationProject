<Window x:Class="GraduationProject.Admin.Management_users"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject.Admin"
        mc:Ignorable="d" Icon="/Images/Logo.png"
        Title="ГИБДД: Управление пользователями" Height="1000" Width="1900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Background.jpg"/>
        </Grid.Background>
        <DataGrid FontSize="16" Name="data_grid_table_users" BeginningEdit="data_grid_table_users_beginning_edit" 
          CanUserAddRows="False" AutoGenerateColumns="False" ColumnWidth="*" RowHeight="35"
          SelectionChanged="data_grid_table_users_selected"
          HeadersVisibility="Column" RowHeaderWidth="0" Margin="189,87,189,218">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="id" Visibility="Hidden" Binding="{Binding id}"/>

                <DataGridTextColumn Header="Логин" Binding="{Binding login}"/>

                <DataGridTextColumn Header="Пароль" Binding="{Binding password}"/>

                <DataGridTextColumn Header="token сотрудника"
                    Visibility="Hidden"
                    Binding="{Binding employee_token}"/>

                <DataGridComboBoxColumn x:Name="column_employee"
                        Header="ФИО"
                        SelectedValueBinding="{Binding employee_token}"
                        SelectedValuePath="token"
                        DisplayMemberPath="fio"/>

                <DataGridTextColumn Header="id роли"
                    Visibility="Hidden"
                    Binding="{Binding role_id}"/>

                <DataGridComboBoxColumn x:Name="column_role"
                        Header="Роль"
                        SelectedValueBinding="{Binding role_id}"
                        SelectedValuePath="id"
                        DisplayMemberPath="name"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Добавить" Click="Button_Click_add" FontSize="24" HorizontalAlignment="Right" Margin="0,0,160,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Сохранить" Name="Button_save" Click="Button_Click_save" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,389,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
        <Button Content="Редактировать" Name="Button_edit" Click="Button_Click_edit" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,623,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
        <Button Content="Удалить"
        Name="Button_delete"
        Click="Button_Click_delete"
        IsEnabled="False"
        FontSize="24"
        HorizontalAlignment="Right"
        Margin="0,0,857,31"
        VerticalAlignment="Bottom"
        Height="66"
        Width="172"/>
    </Grid>
</Window>