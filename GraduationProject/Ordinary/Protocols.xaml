<Window x:Class="GraduationProject.Ordinary.Protocols"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject.Ordinary"
        mc:Ignorable="d"
        Icon="/Images/Logo.png"
        Title="ГИБДД: Протоколы" Height="1000" Width="1900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <DataGrid FontSize="16"
          CanUserAddRows="False"
          BorderThickness="0"
          GridLinesVisibility="All"
          HorizontalGridLinesBrush="#696969"
          VerticalGridLinesBrush="#696969"
          Name="data_grid_protocols"
          AutoGenerateColumns="False"
          ColumnWidth="*"
          RowHeight="35"
          HeadersVisibility="Column"
          RowHeaderWidth="0"
          Margin="0,0,0,102"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          CanUserResizeColumns="True"
          VerticalContentAlignment="Center">
            <DataGrid.Background>
                <ImageBrush ImageSource="/Images/Background.jpg"/>
            </DataGrid.Background>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="id протокола"
                    Binding="{Binding [protocol_id]}"
                    Width="90"/>

                <DataGridTextColumn Header="Дата протокола"
                            Binding="{Binding [protocol_date]}"
                            Width="1*"/>

        <DataGridTextColumn Header="Источник"
                            Binding="{Binding [protocol_source]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Место"
                            Binding="{Binding [place]}"
                            Width="1.5*"/>

        <DataGridTextColumn Header="Статья"
                            Binding="{Binding [law_article]}"
                            Width="0.7*"/>

        <DataGridTextColumn Header="Код"
                            Binding="{Binding [law_code]}"
                            Width="0.7*"/>

        <DataGridTextColumn Header="id автомобиля"
                            Visibility="Collapsed"
                            Binding="{Binding [car_id]}"/>

        <DataGridTextColumn Header="Марка"
                            Binding="{Binding [car_mark]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Модель"
                            Binding="{Binding [car_model]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Цвет"
                            Binding="{Binding [car_color]}"
                            Width="0.7*"/>

        <DataGridTextColumn Header="id госномера"
                            Visibility="Collapsed"
                            Binding="{Binding [state_number_id]}"/>

        <DataGridTextColumn Header="Гос. номер"
                            Binding="{Binding [state_number]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Роль участника"
                            Binding="{Binding [member_role]}"
                            Width="0.9*"/>

        <DataGridTextColumn Header="id участника"
                            Visibility="Collapsed"
                            Binding="{Binding [people_id]}"/>

        <DataGridTextColumn Header="Фамилия участника"
                            Binding="{Binding [people_last_name]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Имя участника"
                            Binding="{Binding [people_first_name]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Отчество участника"
                            Binding="{Binding [people_middle_name]}"
                            Width="0.8*"/>

                <DataGridTemplateColumn Header="Описание" Width="350">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding [description]}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"
                       Padding="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="token сотрудника"
                            Visibility="Collapsed"
                            Binding="{Binding [employee_token]}"/>

        <DataGridTextColumn Header="Фамилия сотрудника"
                            Binding="{Binding [employee_last_name]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Имя сотрудника"
                            Binding="{Binding [employee_first_name]}"
                            Width="0.8*"/>

        <DataGridTextColumn Header="Отчество сотрудника"
                            Binding="{Binding [employee_middle_name]}"
                            Width="0.8*"/>

    </DataGrid.Columns>
</DataGrid>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Добавить" Click="Button_Click_add" FontSize="24" HorizontalAlignment="Right" Margin="0,0,160,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
        <Button Content="Сохранить" Name="Button_save" Click="Button_Click_save" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,389,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
        <Button Content="Редактировать" Name="Button_edit" Click="Button_Click_edit" IsEnabled="False" FontSize="24" HorizontalAlignment="Right" Margin="0,0,623,31" VerticalAlignment="Bottom" Height="66" Width="172"/>
        <Button Content="Удалить"
        Name="Button_delete"
        Click="Button_Click_delete"
        IsEnabled="False"
        FontSize="24"
        HorizontalAlignment="Right"
        Margin="0,0,857,31"
        VerticalAlignment="Bottom"
        Height="66"
        Width="172"/>
        <TextBlock Text="Поиск:"
           FontSize="24"
           HorizontalAlignment="Left"
           Margin="240,0,0,51"
           VerticalAlignment="Bottom"/>

        <TextBox Name="TextBox_search"
         TextChanged="TextBox_search_TextChanged"
         FontSize="24"
         HorizontalAlignment="Left"
         Margin="330,0,0,44"
         VerticalAlignment="Bottom"
         Height="40"
         Width="480"
         VerticalContentAlignment="Center"/>
    </Grid>
</Window>