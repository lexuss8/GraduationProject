<Window x:Class="GraduationProject.Ordinary.Cars"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GraduationProject.Ordinary"
        mc:Ignorable="d"
        Title="ГИБДД: Реестр машин" Icon="/Images/Logo.png" Height="1000" Width="1900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" ResizeMode="CanMinimize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Background.jpg"/>
        </Grid.Background>
        <TextBox Name="tb_search" HorizontalAlignment="Center" Margin="0,29,0,0" TextWrapping="Wrap" FontSize="17" VerticalContentAlignment="Center"
        Text="🔍 Поиск" TextChanged="tb_search_text_changed" HorizontalContentAlignment="Center" Width="552" Height="33" VerticalAlignment="Top"
        GotFocus="tb_search_got_focus" LostFocus="tb_search_lost_focus" Foreground="Gray"/>
        <DataGrid Name="data_grid_cars" ItemsSource="{Binding}" AutoGenerateColumns="False" FontSize="15" CanUserAddRows="False"
IsReadOnly="True" Margin="89,89,89,130">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Марка" Binding="{Binding Марка}" />
                <DataGridTextColumn Header="Модель" Binding="{Binding Модель}" />
                <DataGridTextColumn Header="Цвет" Binding="{Binding Цвет}" />
                <DataGridTextColumn Header="Государственный номер" Binding="{Binding Государственный_номер}" />
                <DataGridTextColumn Header="Год выпуска" Binding="{Binding Год_выпуска}" />
                <DataGridTextColumn Header="VIN" Binding="{Binding VIN}" />
                <DataGridTextColumn Header="Двигатель" Binding="{Binding Двигатель}" />
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Фамилия}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding Имя}" />
                <DataGridTextColumn Header="Отчество" Binding="{Binding Отчество}" />
                <DataGridTextColumn Header="Страховая компания" Binding="{Binding Страховая_компания}" />
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Назад" Click="Button_Click_back" FontSize="24" HorizontalAlignment="Left" Margin="42,0,0,31" VerticalAlignment="Bottom" Height="66" Width="171"/>
    </Grid>
</Window>
